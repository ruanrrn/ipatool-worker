{
  "name": "ipa-tool",
  "version": "2.4.2",
  "description": "Private single-user IPA download / signing tool — Cloudflare Worker + R2 + WASM",
  "type": "module",
  "scripts": {
    "dev": "vite --config frontend/vite.config.js",
    "build": "vite build --config frontend/vite.config.js",
    "build:wasm": "wasm-pack build ipa-wasm --target web --release --out-dir ../frontend/public/wasm --out-name ipa_wasm",
    "build:all": "npm run build:wasm && npm run build",
    "preview": "vite preview --config frontend/vite.config.js",
    "deploy": "wrangler deploy",
    "worker:dev": "wrangler dev",
    "worker:test": "cd worker && npm test",
    "worker:typecheck": "cd worker && npm run typecheck",
    "test:wasm": "cargo test --manifest-path ipa-wasm/Cargo.toml",
    "lint": "eslint frontend/ --config frontend/eslint.config.js",
    "lint:fix": "eslint frontend/ --fix",
    "format": "prettier --config frontend/.prettierrc --write \"frontend/**/*.{vue,js,json,css}\"",
    "postinstall": "cd worker && npm install --ignore-scripts"
  },
  "dependencies": {
    "@radix-ui/colors": "^3.0.0",
    "@vueuse/core": "^14.2.0",
    "pinia": "^2.3.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "postcss": "^8.4.49",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.11",
    "wrangler": "^3.78.0"
  }
}
