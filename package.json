{
  "name": "ipa-tool",
  "version": "1.0.5",
  "description": "A modern IPA download and signing tool with app search capabilities",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:rust": "./dev-rust.sh",
    "build": "vite build",
    "build:rust": "./build-rust.sh",
    "preview": "vite preview",
    "version:sync": "./sync-version.sh",
    "version:patch": "npm version patch && ./sync-version.sh",
    "version:minor": "npm version minor && ./sync-version.sh",
    "version:major": "npm version major && ./sync-version.sh",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{vue,js,json,css}\"",
    "lint:tokens": "bash scripts/check-no-hardcoded-colors.sh"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@radix-ui/colors": "^3.0.0",
    "@vueuse/core": "^14.2.0",
    "element-plus": "^2.13.2",
    "jszip": "^3.10.1",
    "pinia": "^2.3.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "postcss": "^8.4.49",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.17",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^6.0.11"
  }
}
